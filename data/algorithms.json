    "visualizer_config": {
      "type": "graph",
      "initial_pattern": "random",
      "engine_params": { "default_speed": 600, "default_size": 10 }
    },
    "implementations": [
      {
        "language": "javascript",
        "snippet": "function dfs(graph, node, visited = new Set()) {\n  if (visited.has(node)) return;\n  visited.add(node);\n  for (let neighbor of graph[node]) {\n    dfs(graph, neighbor, visited);\n  }\n}",
        "explanation": { "en": "Uses recursion (stack) to explore as deep as possible before backtracking." }
      }
    ],
    "documentation": {
      "description": { "en": "Explores a branch fully before moving to neighbors." },
      "how_it_works": [
        { "en": "Visit a node and mark it visited." },
        { "en": "Recursively visit every unvisited neighbor." }
      ],
      "applications": [
        { "en": "Topological sorting, cycle detection." }
      ]
    },
