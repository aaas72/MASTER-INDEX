    "metadata": {
      "title": { "en": "Depth-First Search" },
      "subtitle": { "en": "Deep exploration graph traversal" },
      "category": "Pathfinding & Networks",
      "tags": ["graph", "backtracking", "recursive"]
    },
    "complexity": {
