  "knapsack-01": {
    "metadata": {
      "title": { "en": "0/1 Knapsack" },
      "subtitle": { "en": "Value optimization under weight constraint" },
      "category": "Dynamic Programming",
      "tags": ["optimization", "matrix-dp", "np-complete"]
    },
    "complexity": {
      "time": {
        "best": { "label": "O(n*W)", "rank": 5 },
        "average": { "label": "O(n*W)", "rank": 5 },
        "worst": { "label": "O(n*W)", "rank": 5 }
      },
      "space": { "label": "O(n*W)", "rank": 5 }
    },
    "visualizer_config": {
      "type": "matrix",
      "initial_pattern": "empty",
      "engine_params": { "default_speed": 1000, "default_size": 10 }
    },
    "implementations": [
      {
        "language": "javascript",
        "snippet": "function knapsack(W, weights, values, n) {\n  let dp = Array(n+1).fill().map(() => Array(W+1).fill(0));\n  for (let i = 1; i <= n; i++) {\n    for (let w = 1; w <= W; w++) {\n      if (weights[i-1] <= w)\n        dp[i][w] = Math.max(values[i-1] + dp[i-1][w-weights[i-1]], dp[i-1][w]);\n      else\n        dp[i][w] = dp[i-1][w];\n    }\n  }\n  return dp[n][W];\n}",
        "explanation": { "en": "Builds a 2D table to store maximum values for every sub-capacity." }
      }
    ],
    "documentation": {
      "description": { "en": "Solves the classical item selection problem." },
      "how_it_works": [
        { "en": "Build a matrix where rows are items and columns are weights." },
        { "en": "Decision: either take the item or leave it." }
      ],
      "applications": [
        { "en": "Resource allocation, Budgeting." }
      ]
    },
