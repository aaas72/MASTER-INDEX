{
  "bubble-sort": {
    "metadata": {
      "title": { "en": "Bubble Sort" },
      "subtitle": { "en": "Simple exchange-based sorting" },
      "category": "Sorting",
      "tags": ["simple", "stable", "in-place"]
    },
    "complexity": {
      "time": {
        "best": { "label": "O(n)", "rank": 3 },
        "average": { "label": "O(n^2)", "rank": 5 },
        "worst": { "label": "O(n^2)", "rank": 5 }
      },
      "space": { "label": "O(1)", "rank": 1 }
    },
    "visualizer_config": {
      "type": "bars",
      "initial_pattern": "random",
      "engine_params": { "default_speed": 400, "default_size": 12 }
    },
    "implementations": [
      {
        "language": "javascript",
        "snippet": "function bubbleSort(arr) {\n  for (let i = 0; i < arr.length; i++) {\n    for (let j = 0; j < arr.length - i - 1; j++) {\n      if (arr[j] > arr[j + 1]) {\n        [arr[j], arr[j+1]] = [arr[j+1], arr[j]];\n      }\n    }\n  }\n  return arr;\n}",
        "explanation": { "en": "Compares adjacent elements and swaps them if they are in the wrong order." }
      }
    ],
    "documentation": {
      "description": { "en": "A simple sorting algorithm that compares adjacent elements." },
      "how_it_works": [
        { "en": "Start from the first element and compare with the second." },
        { "en": "If the first is larger, swap them." },
        { "en": "Repeat for every adjacent pair." }
      ],
      "applications": [
        { "en": "Educational purposes due to its simplicity." }
      ]
    },
    "simulation_trace": [
      {
        "step": 1,
        "description": { "en": "Initial unsorted array." },
        "active_line": 1,
        "state_snapshot": {
          "array": [8, 3, 5, 1, 9, 2, 7, 4, 6]
        }
      }
    ]
  },
  "quick-sort": {
    "metadata": {
      "title": { "en": "Quick Sort" },
      "subtitle": { "en": "High-performance divide and conquer" },
      "category": "Sorting",
      "tags": ["efficient", "recursive", "divide-and-conquer"]
    },
    "complexity": {
      "time": {
        "best": { "label": "O(n log n)", "rank": 4 },
        "average": { "label": "O(n log n)", "rank": 4 },
        "worst": { "label": "O(n^2)", "rank": 5 }
      },
      "space": { "label": "O(log n)", "rank": 2 }
    },
    "visualizer_config": {
      "type": "bars",
      "initial_pattern": "reverse_sorted",
      "engine_params": { "default_speed": 300, "default_size": 15 }
    },
    "implementations": [
      {
        "language": "javascript",
        "snippet": "function quickSort(arr) {\n  if (arr.length <= 1) return arr;\n  const pivot = arr[arr.length - 1];\n  const left = [];\n  const right = [];\n  for (let i = 0; i < arr.length - 1; i++) {\n    if (arr[i] < pivot) left.push(arr[i]);\n    else right.push(arr[i]);\n  }\n  return [...quickSort(left), pivot, ...quickSort(right)];\n}",
        "explanation": { "en": "Picks a pivot and partitions the array around it." }
      }
    ],
    "documentation": {
      "description": { "en": "A divide-and-conquer sorting algorithm." },
      "how_it_works": [
        { "en": "Choose a pivot element." },
        { "en": "Partition the array into smaller and larger elements." },
        { "en": "Recursively repeat for sub-arrays." }
      ],
      "applications": [
        { "en": "Sorting large datasets." }
      ]
    }
  },
  "merge-sort": {
    "metadata": {
      "title": { "en": "Merge Sort" },
      "subtitle": { "en": "Stable divide and conquer" },
      "category": "Sorting",
      "tags": ["stable", "guaranteed-performance", "recursive"]
    },
    "complexity": {
      "time": {
        "best": { "label": "O(n log n)", "rank": 4 },
        "average": { "label": "O(n log n)", "rank": 4 },
        "worst": { "label": "O(n log n)", "rank": 4 }
      },
      "space": { "label": "O(n)", "rank": 3 }
    },
    "visualizer_config": {
      "type": "bars",
      "initial_pattern": "random",
      "engine_params": { "default_speed": 350, "default_size": 20 }
    },
    "implementations": [
      {
        "language": "javascript",
        "snippet": "function mergeSort(arr) {\n  if (arr.length <= 1) return arr;\n  const mid = Math.floor(arr.length / 2);\n  const left = mergeSort(arr.slice(0, mid));\n  const right = mergeSort(arr.slice(mid));\n  return merge(left, right);\n}",
        "explanation": { "en": "Divides the array into halves and merges them in order." }
      }
    ],
    "documentation": {
      "description": { "en": "A stable sorting algorithm that divides and merges." },
      "how_it_works": [
        { "en": "Recursively divide array into halves." },
        { "en": "Merge small arrays in a sorted manner." }
      ],
      "applications": [
        { "en": "Linked list sorting." }
      ]
    },
    "simulation_trace": [
