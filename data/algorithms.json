    "implementations": [
      {
        "language": "javascript",
        "snippet": "function fib(n, memo = {}) {\n  if (n in memo) return memo[n];\n  if (n <= 2) return 1;\n  memo[n] = fib(n-1, memo) + fib(n-2, memo);\n  return memo[n];\n}",
        "explanation": { "en": "Uses a memo table to avoid redundant recursive calls." }
      }
    ],
    "documentation": {
      "description": { "en": "Computes Fibonacci numbers efficiently using Dynamic Programming." },
      "how_it_works": [
        { "en": "Check if value is in memo." },
        { "en": "If not, calculate recursively and store." }
      ],
